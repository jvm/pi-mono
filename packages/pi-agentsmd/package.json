{
  "name": "pi-agentsmd",
  "version": "0.1.1",
  "description": "Generate AGENTS.md contributor guides for Pi repositories.",
  "type": "module",
  "license": "MIT",
  "author": "Jose Mocito",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jvm/pi-mono.git",
    "directory": "packages/pi-agentsmd"
  },
  "bugs": {
    "url": "https://github.com/jvm/pi-mono/issues"
  },
  "homepage": "https://github.com/jvm/pi-mono/tree/main/packages/pi-agentsmd#readme",
  "keywords": [
    "pi-package",
    "pi-extension",
    "pi",
    "agents-md",
    "documentation",
    "repository-guidelines"
  ],
  "exports": {
    ".": "./src/index.ts"
  },
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "files": [
    "index.ts",
    "extensions",
    "src",
    "prompts",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "SECURITY.md",
    "CONTRIBUTING.md",
    "CODE_OF_CONDUCT.md",
    "THIRD-PARTY-NOTICES"
  ],
  "scripts": {
    "check": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "pack:dry-run": "npm pack --dry-run"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.78.1",
    "@types/node": "^25.9.2",
    "typescript": "^6.0.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.6.0"
  }
}
