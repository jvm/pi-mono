{
  "name": "pi-insomnia",
  "version": "0.1.0",
  "description": "Prevent macOS idle sleep while Pi agents are working.",
  "type": "module",
  "license": "MIT",
  "author": "Jose Mocito",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jvm/pi-mono.git",
    "directory": "packages/pi-insomnia"
  },
  "bugs": {
    "url": "https://github.com/jvm/pi-mono/issues"
  },
  "homepage": "https://github.com/jvm/pi-mono/tree/main/packages/pi-insomnia#readme",
  "keywords": [
    "pi-package",
    "pi-extension",
    "pi",
    "macos",
    "sleep",
    "caffeinate",
    "insomnia"
  ],
  "exports": {
    ".": "./src/index.ts"
  },
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "files": [
    "index.ts",
    "extensions",
    "src",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "SECURITY.md",
    "CONTRIBUTING.md",
    "CODE_OF_CONDUCT.md"
  ],
  "scripts": {
    "check": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "pack:dry-run": "npm pack --dry-run"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.78.0",
    "@types/node": "^25.6.2",
    "typescript": "^6.0.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.6.0"
  }
}
